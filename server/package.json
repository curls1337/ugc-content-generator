{
  "name": "ugc-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.mjs --external:playwright --external:playwright-extra --external:puppeteer-extra-plugin-stealth --external:@google/generative-ai --external:express --external:cors --keep-names=false --alias:@shared/types=../shared/src/types.ts --alias:@shared/utils=../shared/src/utils/index.ts --alias:@shared/utils/index=../shared/src/utils/index.ts --alias:@shared/utils/platform-detection=../shared/src/utils/platform-detection.ts --alias:@shared/api-types=../shared/src/api-types.ts",
    "build": "npm run bundle",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "esbuild": "^0.21.0"
  }
}
